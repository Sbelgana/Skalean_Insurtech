# VARIABLES D'ENVIRONNEMENT skalean-insurtech v2.0 -- CONFIGURATION COMPLETE
# Version: 2.0.0
# Date: 2026-05-04
# Description: Variables pour developpement local et sandbox CI
# AUCUNE EMOJI AUTORISEE
#
# Changelog v2.0:
# - Ajout variables 3 apps clientes (URLs, ports)
# - Ajout Mapbox configuration
# - Ajout KYC seuils et delais validation courtier
# - Ajout PostHog analytics marketing
# - Ajout configuration sessions prospects
#
# IMPORTANT :
# - Ce fichier sert de reference et de template (.env.example)
# - En production, toutes les valeurs sont chargees depuis HashiCorp Vault
# - Le fichier .env reel est dans .gitignore et ne doit JAMAIS etre commite

# ==========================================
# APPLICATION GENERALE
# ==========================================

NODE_ENV=development
APP_NAME=skalean-insurtech
APP_VERSION=2.0.0
APP_PORT=4000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:4000
APP_PUBLIC_URL=https://api.skalean-insurtech.ma
APP_TIMEZONE=Africa/Casablanca
APP_LOCALE_DEFAULT=fr
APP_LOCALES_SUPPORTED=fr,ar-MA,ar

# ==========================================
# URLS DES 8 APPLICATIONS v2.0
# ==========================================

# API
API_BASE_URL=http://localhost:4000
API_PUBLIC_URL=https://api.skalean-insurtech.ma

# Apps SaaS B2B (existantes)
WEB_BROKER_URL=http://localhost:3001
WEB_BROKER_PUBLIC_URL=https://broker.skalean-insurtech.ma
