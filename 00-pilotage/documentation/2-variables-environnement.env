WEB_ASSURE_MOBILE_PUBLIC_URL=https://mon-espace.skalean-insurtech.ma

# ==========================================
# DATABASE -- PostgreSQL (inchange)
# ==========================================

DATABASE_URL=postgresql://insurtech_user:SecurePassword123!@localhost:5432/insurtech?schema=public&connection_limit=100
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=insurtech
DATABASE_USER=insurtech_user
DATABASE_PASSWORD=SecurePassword123!
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_CONNECTION_LIMIT=100
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=100
DATABASE_POOL_IDLE_TIMEOUT=30000
DATABASE_STATEMENT_TIMEOUT=30000
DATABASE_QUERY_TIMEOUT=10000
DATABASE_LOG_QUERIES=false
DATABASE_SYNCHRONIZE=false

PGBOUNCER_HOST=localhost
PGBOUNCER_PORT=6432
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=100

# ==========================================
# REDIS (mise a jour v2.0)
# ==========================================

REDIS_URL=redis://default:RedisPassword456!@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisPassword456!
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=insurtech:
REDIS_TTL_DEFAULT=300
REDIS_MAX_RETRIES=3

# Redis pour BullMQ queues
REDIS_QUEUE_URL=redis://default:RedisPassword456!@localhost:6379/1
REDIS_QUEUE_DB=1

# Redis pour cache Skalean AI responses
REDIS_AI_CACHE_URL=redis://default:RedisPassword456!@localhost:6379/2
REDIS_AI_CACHE_DB=2
REDIS_AI_CACHE_TTL=3600

# Redis pour sessions prospects (NOUVEAU v2.0)
REDIS_PROSPECT_SESSIONS_URL=redis://default:RedisPassword456!@localhost:6379/3
REDIS_PROSPECT_SESSIONS_DB=3
REDIS_PROSPECT_SESSIONS_TTL=1800

# ==========================================
# KAFKA -- Event Bus (inchange)
# ==========================================

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=insurtech-api
KAFKA_GROUP_ID=insurtech-consumers
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=plain
KAFKA_SASL_USERNAME=insurtech_user
KAFKA_SASL_PASSWORD=KafkaPassword789!
KAFKA_RETRY_INITIAL_RETRY_TIME=300
KAFKA_RETRY_RETRIES=8
KAFKA_TOPIC_PREFIX=insurtech.events
KAFKA_DLQ_SUFFIX=.dlq

# ==========================================
# AUTHENTICATION -- JWT (inchange)
# ==========================================

JWT_PRIVATE_KEY_PATH=./secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt-public.pem
JWT_ALGORITHM=ES256
JWT_ISSUER=skalean-insurtech
JWT_AUDIENCE=insurtech-clients
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
JWT_REFRESH_TOKEN_ROTATION=true

# Argon2id parameters
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Lockout configuration
AUTH_LOCKOUT_MAX_ATTEMPTS=5
AUTH_LOCKOUT_DURATION_SECONDS=900

# MFA TOTP
MFA_TOTP_ISSUER=Skalean InsurTech
MFA_TOTP_WINDOW=1
MFA_BACKUP_CODES_COUNT=10

# ==========================================
# WEB-CUSTOMER-PORTAL CONFIGURATION (NOUVEAU v2.0)
# ==========================================

# Sessions prospects
PROSPECT_SESSION_TTL_SECONDS=1800
PROSPECT_SESSION_COOKIE_NAME=insurtech_prospect_session
PROSPECT_SESSION_COOKIE_SECURE=true
PROSPECT_SESSION_COOKIE_SAMESITE=lax
PROSPECT_QUOTE_REQUEST_TTL_DAYS=30

# Cotation comparator
COTATION_PARALLEL_TIMEOUT_MS=10000
COTATION_MIN_INSURERS_REQUIRED=3
COTATION_MAX_RESULTS_DISPLAYED=10

# Rate limiting endpoints publics
PUBLIC_QUOTE_RATE_LIMIT_PER_MIN=30
PUBLIC_QUOTE_RATE_LIMIT_PER_IP_PER_HOUR=100

# Repartition automatique courtiers
BROKER_ASSIGNMENT_ALGORITHM=round_robin  # round_robin | by_region | least_busy
BROKER_ASSIGNMENT_FALLBACK_TENANT_ID=00000000-0000-0000-0000-000000000000

# Validation courtier (file d'attente)
BROKER_VALIDATION_SLA_HOURS=24
BROKER_VALIDATION_REMINDER_AT_HOURS=12,18,22
BROKER_VALIDATION_AUTO_ESCALATE_HOURS=48

# Document provisoire
PROVISIONAL_POLICY_TTL_DAYS=7
PROVISIONAL_POLICY_AUTO_RENEW_ENABLED=false

# ==========================================
# KYC ET PRE-APPROBATION (NOUVEAU v2.0)
# ==========================================

# Seuils de score Skalean AI Agents
KYC_AUTO_APPROVAL_THRESHOLD=0.85
KYC_MANUAL_REVIEW_THRESHOLD=0.65
