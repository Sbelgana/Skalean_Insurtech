KYC_REQUIRED_DOCS_SANTE=cin_recto,cin_verso,attestation_employeur
KYC_REQUIRED_DOCS_VIE=cin_recto,cin_verso,releve_bancaire

# Limites upload
KYC_MAX_FILE_SIZE_MB=10
KYC_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
