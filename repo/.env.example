# Skalean InsurTech v2.2 -- Variables d'environnement exemple
# COPIER ce fichier en .env pour l'environnement local
# NE JAMAIS committer .env (contient les secrets)
# Reference: task-1.1.8 (shared-config Zod loader) + task-1.1.3 (Docker services)
# Aucune emoji autorisee (decision-006)

# ============================================================================
# Node environment
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================================================
# PostgreSQL
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=skalean
POSTGRES_PASSWORD=skalean_dev_only_change_in_prod
POSTGRES_DB=skalean_insurtech
DATABASE_URL=postgresql://skalean:skalean_dev_only_change_in_prod@localhost:5432/skalean_insurtech
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ============================================================================
# Redis
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=skalean_redis_dev_only
REDIS_URL=redis://:skalean_redis_dev_only@localhost:6379

# ============================================================================
# Kafka
# ============================================================================
KAFKA_BROKERS=localhost:9094
KAFKA_CLIENT_ID=skalean-api
KAFKA_GROUP_ID=skalean-insurtech-dev

# ============================================================================
# MinIO / S3 (dev local)
# ============================================================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=ma-bgr-1
S3_ACCESS_KEY_ID=skalean
S3_SECRET_ACCESS_KEY=skalean_minio_dev_only
S3_FORCE_PATH_STYLE=true
S3_BUCKET_DOCS=skalean-insurtech-dev-docs
S3_BUCKET_PHOTOS=skalean-insurtech-dev-photos
S3_BUCKET_ARCHIVE=skalean-insurtech-dev-archive

# ============================================================================
# JWT / Auth
# ============================================================================
JWT_SECRET=dev_jwt_secret_must_be_at_least_32_chars_long_xxxx
JWT_REFRESH_SECRET=dev_refresh_secret_must_be_at_least_32_chars_long_xx
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
MFA_SECRET_ENCRYPTION_KEY=dev_mfa_key_32chars_minimum_here_xx

# ============================================================================
# Mailhog (dev SMTP)
# ============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=noreply@skalean-dev.ma

# ============================================================================
# n8n
# ============================================================================
N8N_PORT=5678
N8N_BASIC_AUTH_USER=skalean
N8N_BASIC_AUTH_PASSWORD=skalean_n8n_dev_only

# ============================================================================
# Sentry (optionnel en dev)
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ============================================================================
# OpenTelemetry (optionnel en dev)
# ============================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=skalean-insurtech-api
