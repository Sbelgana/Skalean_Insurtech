# ============================================================================
# Skalean InsurTech v2.2 -- Variables d'environnement tests integration
# Reference: Tache 1.2.15 -- Tests integration end-to-end
# Copier vers .env.test et adapter si necessaire.
# Aucune emoji (decision-006).
# ============================================================================

NODE_ENV=test
DATABASE_TEST_URL=postgres://test:test@localhost:5433/skalean_test
KAFKA_TEST_BROKERS=localhost:9093
REDIS_TEST_URL=redis://localhost:6380

# Timeouts tests (ms)
TEST_TIMEOUT_MS=60000
TEST_TRUNCATE_BEFORE_EACH=true
TEST_KAFKA_CONSUMER_GROUP_PREFIX=test
TEST_PARALLEL=false
TEST_LOG_LEVEL=error

# Reproductibilite seeds
TEST_SEED_RANDOM=42
FAKER_SEED=42

# Tenants fixtures
TEST_DEFAULT_TENANT_A=00000000-0000-0000-0000-00000000000a
TEST_DEFAULT_TENANT_B=00000000-0000-0000-0000-00000000000b
TEST_DEFAULT_TENANT_C=00000000-0000-0000-0000-00000000000c

# DLQ
TEST_DLQ_RETENTION_HOURS=72
TEST_IDEMPOTENCY_TTL_SECONDS=86400

# OpenTelemetry -- desactive en tests pour eviter blocage
OTEL_TRACES_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_METRICS_EXPORTER=none

# Kafka
TEST_KAFKA_CLIENT_ID_PREFIX=skalean-test

# Postgres
TEST_PG_STATEMENT_TIMEOUT_MS=15000

# Hooks Vitest
TEST_HOOK_TIMEOUT_MS=60000
TEST_TEARDOWN_TIMEOUT_MS=30000

# Vitest retry
TEST_RETRY_COUNT=1

# Coverage thresholds
TEST_COVERAGE_THRESHOLD_LINES=80
TEST_COVERAGE_THRESHOLD_BRANCHES=70

# Seeds connexion (si different de DATABASE_TEST_URL)
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=test
DATABASE_PASSWORD=test
DATABASE_NAME=skalean_test
SEED_RANDOM_SEED=42
SEED_PASSWORD_DEFAULT=Demo!2026Skalean
SEED_TIMEZONE=Africa/Casablanca
