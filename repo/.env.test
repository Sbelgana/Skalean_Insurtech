# Skalean InsurTech / Assurflow v3.0 -- Test stack env defaults
# Generated Sprint 7.5b Tache 7.5b.0 (recommandation Pause #5 standardisation port Kafka).
#
# Usage : `source .env.test` ou `export $(cat .env.test | xargs)`
# Aucune emoji (decision-006).

# Skip auto-docker-up dans global-setup.ts (containers UP via infrastructure/docker/docker-compose.test.yaml)
SKALEAN_CI=true

# Postgres test (port 5433, db skalean_insurtech_test, user skalean)
TEST_DATABASE_HOST=localhost
TEST_DATABASE_PORT=5433
TEST_DATABASE_USER=skalean
TEST_DATABASE_PASSWORD=skalean_test
TEST_DATABASE_NAME=skalean_insurtech_test
DATABASE_URL=postgresql://skalean:skalean_test@localhost:5433/skalean_insurtech_test

# Redis test (port 6380)
REDIS_URL=redis://localhost:6380

# Kafka test (port 9095 -- standardise post-Pause #5)
# Note : le prompt original Pause #5 mentionnait 9093 mais le compose UP utilise 9095.
# Decision Sprint 7.5b : KAFKA_PORT=9095 est le port officiel test stack v3.0.
KAFKA_BROKERS=localhost:9095
KAFKA_CLIENT_ID=insurtech-api-test

# OpenTelemetry : disable pour tests
OTEL_TRACES_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_METRICS_EXPORTER=none

# Node
NODE_ENV=test

# Sprint 8.10 -- Calendar Sync (foundation)
# Dev-only AES-256-GCM key. Generated 2026-05-24 via openssl rand -hex 32. NOT FOR PROD.
CALENDAR_TOKEN_ENCRYPTION_KEY=c65fcd3a9dcb54c0532d4be3da517380bf5d425036d929cd8b4acf67cdad1e02
CALENDAR_SYNC_AUTO_DISABLE_THRESHOLD=5
