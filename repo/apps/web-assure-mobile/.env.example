# web-assure-mobile -- variables d'environnement
# Reference : task-1.4.7 Sprint 4 Phase 1
# Copier en .env.local et remplir les valeurs

# URL de l'API backend
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL publique de l'application (utilisee pour les metadonnees OG)
NEXT_PUBLIC_APP_URL=http://localhost:3006

# CDN pour les assets media (laisser vide en developpement)
NEXT_PUBLIC_CDN_URL=

# Locale par defaut
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Sentry DSN (laisser vide pour desactiver)
NEXT_PUBLIC_SENTRY_DSN=

# Header tenant
NEXT_PUBLIC_TENANT_ID_HEADER=x-tenant-id

# PWA active en production uniquement
NEXT_PUBLIC_PWA_ENABLED=false
