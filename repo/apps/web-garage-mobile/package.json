    "@tanstack/react-query-devtools": "5.62.7",
    "axios": "1.7.9",
    "zod": "3.24.1",
    "zustand": "5.0.2",
    "@sentry/nextjs": "8.47.0",
    "pino": "9.5.0",
    "clsx": "2.1.1",
    "tailwind-merge": "2.5.5",
    "lucide-react": "0.469.0",
    "sonner": "1.7.1",
    "idb": "8.0.0",
