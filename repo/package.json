{
  "name": "skalean-insurtech",
  "version": "2.2.0",
  "description": "Plateforme InsurTech Marocaine v2.2 -- 9 apps + 23 packages monorepo pnpm + Turborepo. Multi-tenant 3 niveaux (Platform / Customer Tenant / Assure). Conformite ACAPS + DGI + CNDP + AMC + Loi 43-20 signature electronique. Atlas Cloud Services Benguerir (souverainete Maroc).",
  "private": true,
  "type": "module",
  "license": "PROPRIETARY",
  "author": "Skalean SARL <contact@skalean.ma>",
  "homepage": "https://skalean-insurtech.ma",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/skalean/insurtech.git"
  },
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=9.15.0 <10.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "volta": {
    "node": "22.22.1",
    "pnpm": "9.15.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --concurrency=15",

    "dev:web-broker": "pnpm --filter @insurtech/web-broker dev",
    "dev:web-garage": "pnpm --filter @insurtech/web-garage dev",
    "dev:web-garage-mobile": "pnpm --filter @insurtech/web-garage-mobile dev",
    "dev:web-insurtech-admin": "pnpm --filter @insurtech/web-insurtech-admin dev",
    "dev:web-customer-portal": "pnpm --filter @insurtech/web-customer-portal dev",
    "dev:web-assure-portal": "pnpm --filter @insurtech/web-assure-portal dev",
    "dev:web-assure-mobile": "pnpm --filter @insurtech/web-assure-mobile dev",

    "dev:portals": "bash scripts/dev-portals.sh",
    "dev:dashboards": "bash scripts/dev-dashboards.sh",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:portals:win": "scripts\\dev-portals.cmd",
    "dev:dashboards:win": "scripts\\dev-dashboards.cmd",
    "dev:all:win": "scripts\\dev-all.cmd",

    "build": "turbo run build",
    "build:affected": "turbo run build --filter=...[origin/main]",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:packages": "turbo run build --filter='./packages/*'",

    "typecheck": "turbo run typecheck",
    "typecheck:apps": "turbo run typecheck --filter='./apps/*'",
    "typecheck:packages": "turbo run typecheck --filter='./packages/*'",

    "lint": "turbo run lint && node_modules/.bin/biome check .",
    "lint:fix": "turbo run lint:fix && node_modules/.bin/biome check --write .",
    "lint:apps": "turbo run lint --filter='./apps/*'",

    "format": "node_modules/.bin/biome format --write .",
    "format:check": "node_modules/.bin/biome format --check .",

    "test": "turbo run test",
    "test:apps": "turbo run test --filter='./apps/*'",
    "test:packages": "turbo run test --filter='./packages/*'",
    "test:watch": "turbo run test -- --watch",
    "test:coverage": "turbo run test -- --coverage",
    "test:e2e": "turbo run test:e2e",
    "test:structure": "vitest run infrastructure/scripts/__tests__/structure.spec.ts",
    "test:integration": "turbo run test:integration --concurrency=1",
    "test:integration:coverage": "pnpm --filter @insurtech/database test:integration:coverage && pnpm --filter @insurtech/shared-events test:integration:coverage",

    "doctor": "tsx scripts/doctor.ts",
    "doctor:offline": "tsx scripts/doctor.ts --offline",
    "doctor:fix": "tsx scripts/doctor.ts --fix",

    "generate:api-client": "turbo run generate:api-client --filter=@insurtech/api-client",
    "lighthouse:baseline": "turbo run lighthouse --filter='./apps/*'",

    "storybook": "pnpm --filter @insurtech/shared-ui storybook",
    "storybook:build": "pnpm --filter @insurtech/shared-ui build-storybook",

    "validate": "pnpm typecheck && pnpm lint && pnpm test",
    "ci": "pnpm install --frozen-lockfile && pnpm validate && pnpm build:apps",

    "docker:up": "docker compose -f infrastructure/docker/docker-compose.dev.yaml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.dev.yaml down",
    "docker:reset": "docker compose -f infrastructure/docker/docker-compose.dev.yaml down -v && docker compose -f infrastructure/docker/docker-compose.dev.yaml up -d",
    "docker:logs": "docker compose -f infrastructure/docker/docker-compose.dev.yaml logs -f --tail=100",
    "docker:ps": "docker compose -f infrastructure/docker/docker-compose.dev.yaml ps",

    "bootstrap": "pnpm install --frozen-lockfile && pnpm typecheck && pnpm lint && echo Bootstrap completed",
    "verify-env": "tsx infrastructure/scripts/verify-env.ts",
    "check-no-emoji": "bash infrastructure/scripts/check-no-emoji.sh",
    "seeds:run": "pnpm --filter @insurtech/platform seeds:run",
    "seeds:reset": "pnpm --filter @insurtech/platform seeds:reset",
    "seeds:dev": "pnpm --filter @insurtech/platform seeds:dev",
    "seeds:test": "pnpm --filter @insurtech/platform seeds:test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "clean:all": "pnpm clean && find . -name node_modules -type d -prune -exec rm -rf {} + 2>/dev/null; find . -name .turbo -type d -prune -exec rm -rf {} + 2>/dev/null; find . -name dist -type d -prune -exec rm -rf {} + 2>/dev/null; true",
    "prepare": "node -e \"try{require('child_process').execSync('git -C .. config core.hooksPath repo/.husky',{stdio:'ignore'})}catch(e){}\"",
    "preinstall": "npx -y only-allow pnpm",
    "postinstall": "echo Run pnpm docker:up to start dev services"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@playwright/test": "1.49.1",
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "@vitest/coverage-v8": "2.1.8",
    "concurrently": "9.1.0",
    "dotenv": "16.4.7",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "kafkajs": "2.2.4",
    "lint-staged": "15.2.11",
    "pg": "8.13.1",
    "playwright": "1.49.1",
    "reflect-metadata": "0.2.2",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "turbo": "2.4.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "2.1.8",
    "zod": "3.24.1"
  },
  "pnpm": {
    "overrides": {},
    "peerDependencyRules": {
      "allowedVersions": {},
      "ignoreMissing": []
    }
  }
}
