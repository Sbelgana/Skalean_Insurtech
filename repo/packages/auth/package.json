{
  "name": "@insurtech/auth",
  "version": "0.1.0",
  "description": "Skalean InsurTech v2.2 -- Auth contracts (types, Zod schemas, constants, NestJS module). Initialized in Sprint 5 Tache 2.1.1.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"const f=require('node:fs');f.mkdirSync('dist/data',{recursive:true});f.copyFileSync('src/data/banned-passwords.json','dist/data/banned-passwords.json');f.mkdirSync('dist/services',{recursive:true});f.copyFileSync('src/services/session-rotate.lua','dist/services/session-rotate.lua')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --config vitest.config.ts --coverage --passWithNoTests",
    "lint": "biome check --no-errors-on-unmatched src test",
    "lint:check": "biome check --no-errors-on-unmatched src test",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@node-rs/argon2": "2.0.2",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "reflect-metadata": "0.2.2",
    "ulid": "2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.15",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.10.5",
    "@vitest/coverage-v8": "2.1.8",
    "ioredis-mock": "8.9.0",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  },
  "peerDependencies": {
    "rxjs": "7.8.1"
  },
  "sideEffects": false
}
