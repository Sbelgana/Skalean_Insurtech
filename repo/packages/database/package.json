{
  "name": "@insurtech/database",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check --no-errors-on-unmatched src",
    "clean": "rm -rf dist .turbo",
    "migration:create": "tsx node_modules/typeorm/cli.js migration:create",
    "migration:generate": "tsx node_modules/typeorm/cli.js migration:generate -d ./src/cli-data-source.ts",
    "migration:run": "tsx node_modules/typeorm/cli.js migration:run -d ./src/cli-data-source.ts",
    "migration:revert": "tsx node_modules/typeorm/cli.js migration:revert -d ./src/cli-data-source.ts",
    "migration:show": "tsx node_modules/typeorm/cli.js migration:show -d ./src/cli-data-source.ts",
    "seeds:run": "tsx src/seeds/run-seeds.ts",
    "seeds:reset": "tsx src/seeds/reset-seeds.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:coverage": "vitest run --config vitest.config.integration.ts --coverage"
  },
  "dependencies": {
    "@insurtech/shared-config": "workspace:*",
    "@insurtech/shared-utils": "workspace:*",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.20"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/pg": "8.11.10",
    "ioredis": "5.4.2",
    "kafkajs": "2.2.4",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
