{
  "name": "@insurtech/shared-events",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kafka-publisher": {
      "import": "./dist/kafka-publisher/index.js",
      "types": "./dist/kafka-publisher/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "lint": "biome check --no-errors-on-unmatched src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@opentelemetry/api": "1.9.0",
    "kafkajs": "2.2.4",
    "pino": "9.5.0",
    "reflect-metadata": "0.2.2",
    "ulid": "^2.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "10.4.15",
    "@types/node": "22.10.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
