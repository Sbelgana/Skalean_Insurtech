{
  "name": "@insurtech/shared-maps",
  "version": "0.1.0",
  "private": true,
  "description": "Wrapper React Mapbox GL JS 3.8.0 pour le programme Skalean InsurTech.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles/skalean-style.json": "./src/styles/skalean-style.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check --no-errors-on-unmatched src",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@tanstack/react-query": "5.62.7",
    "mapbox-gl": "3.8.0",
    "supercluster": "8.0.1"
  },
  "peerDependencies": {
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@types/mapbox-gl": "3.4.1",
    "@types/node": "22.10.2",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@types/supercluster": "7.1.3",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "happy-dom": "15.11.7",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "rimraf": "6.0.1",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  }
}
