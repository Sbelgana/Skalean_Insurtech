{
  "name": "@insurtech/shared-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tailwind-preset": {
      "import": "./src/tailwind-preset.ts",
      "require": "./src/tailwind-preset.ts",
      "default": "./src/tailwind-preset.ts"
    },
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/fonts.css": "./src/styles/fonts.css",
    "./components/locale-switcher": {
      "import": "./src/components/locale-switcher.tsx",
      "default": "./src/components/locale-switcher.tsx"
    },
    "./components/theme-toggle": {
      "import": "./src/components/theme-toggle.tsx",
      "default": "./src/components/theme-toggle.tsx"
    },
    "./i18n/routing": "./src/i18n/routing.ts",
    "./i18n/navigation": "./src/i18n/navigation.ts",
    "./i18n/locales": "./src/i18n/locales.ts",
    "./i18n/types": "./src/i18n/types.ts",
    "./i18n": "./src/i18n/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "biome check --no-errors-on-unmatched src",
    "clean": "rm -rf dist .turbo storybook-static",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "clsx": "2.1.1",
    "lucide-react": ">=0.400.0",
    "next": ">=15.0.0",
    "next-intl": ">=3.0.0",
    "next-themes": ">=0.4.0",
    "react": ">=19.0.0",
    "sonner": "1.7.1",
    "tailwind-merge": "2.5.5",
    "zustand": ">=5.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "3.2.2",
    "@storybook/addon-a11y": "8.4.7",
    "@storybook/addon-essentials": "8.4.7",
    "@storybook/addon-interactions": "8.4.7",
    "@storybook/addon-themes": "8.4.7",
    "@storybook/manager-api": "8.4.7",
    "@storybook/nextjs": "8.4.7",
    "@storybook/react": "8.4.7",
    "@storybook/theming": "8.4.7",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "2.1.8",
    "clsx": "2.1.1",
    "lucide-react": "0.469.0",
    "next": "15.1.0",
    "next-intl": "3.26.3",
    "next-themes": "0.4.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sonner": "1.7.1",
    "storybook": "8.4.7",
    "tailwind-merge": "2.5.5",
    "typescript": "5.7.3",
    "vitest": "2.1.8",
    "zustand": "5.0.2"
  }
}
