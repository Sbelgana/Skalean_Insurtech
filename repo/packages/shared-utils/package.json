{
  "name": "@insurtech/shared-utils",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./redis": {
      "types": "./dist/redis/index.d.ts",
      "import": "./dist/redis/index.js",
      "require": "./dist/redis/index.js",
      "default": "./dist/redis/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js",
      "require": "./dist/telemetry/index.js",
      "default": "./dist/telemetry/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --no-errors-on-unmatched ./src",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.703.0",
    "@aws-sdk/lib-storage": "3.703.0",
    "@aws-sdk/s3-request-presigner": "3.703.0",
    "@opentelemetry/auto-instrumentations-node": "0.53.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.55.0",
    "@opentelemetry/resources": "1.28.0",
    "@opentelemetry/sdk-node": "0.55.0",
    "@opentelemetry/semantic-conventions": "1.28.0",
    "@sentry/node": "8.45.0",
    "ioredis": "5.4.2",
    "pino": "9.5.0"
  },
  "devDependencies": {
    "ioredis-mock": "8.9.0",
    "pino-pretty": "13.0.0",
    "vitest": "2.1.8"
  }
}
