{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "outDir": ".tmp-tsc-out"
  },
  "include": [
    "infrastructure/scripts/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/.next",
    "**/.turbo",
    "**/coverage",
    "apps/**/*",
    "packages/**/*"
  ]
}
